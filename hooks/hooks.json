{
  "description": "Core agentic coding workflow hooks - security, testing, permissions, and audit",
  "hooks": {
    "PreToolUse": [
      {
        "description": "Prevents execution of potentially dangerous commands",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/dangerous_command_blocker.py",
            "timeout": 5
          }
        ]
      },
      {
        "description": "Auto-approves read-only tools (Read, Glob, Grep, safe Bash) for all sessions and extra tools for subagents",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent_permission_router.py",
            "timeout": 5
          }
        ]
      },
      {
        "description": "Blocks gh pr create unless PR description exists and user approved it",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ship-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "description": "Logs all tool calls to .claude/logs/tool-calls.jsonl for audit and debugging",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/audit-logger.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "description": "Removes orphaned pr-review-* worktrees left by crashed or interrupted review sessions",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-review-worktrees.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "description": "Logs API failures (rate limits, auth errors) and sends toast notifications for visibility",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-failure-logger.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "description": "Validates command output artifacts exist and contain required sections, blocks stop if incomplete",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-output.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lint-on-stop.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/rule-capture-on-stop.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ralph-on-stop.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/toast-notify.sh"
          }
        ]
      }
    ]
  }
}
